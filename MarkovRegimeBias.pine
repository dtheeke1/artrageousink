//@version=6
indicator("Markov Regime Bias", shorttitle="MRB", overlay=true, max_bars_back=5000)

// ============================================================================
// MARKOV REGIME BIAS  —  Pine Script v6  —  Standalone Indicator
// ============================================================================
//
// WHAT IS A MARKOV CHAIN REGIME MODEL?
// A Markov chain is a probabilistic model where the probability of transitioning
// to the next state depends only on the CURRENT state — not on the full history
// of how we got here. Applied to markets: given that today's bar is in a BULL
// regime, what is the historical likelihood that tomorrow will also be BULL?
// BEAR? SIDEWAYS? We answer this by counting every state-to-state transition in
// history and building a 3×3 matrix of conditional probabilities. The diagonal
// (BULL→BULL, BEAR→BEAR, SIDEWAYS→SIDEWAYS) tells you how "sticky" each regime
// tends to be. Off-diagonal cells show reversal and rotation probabilities.
//
// RESOLUTION TOGGLE  [D / W]:
// "Daily" (default): regime states computed from confirmed daily bars. Works on
//   any chart timeframe. Dashboard shows [D], labels read "Today / Tomorrow."
// "Weekly": regime states computed from confirmed weekly bars. Best used on the
//   daily chart so price context matches regime context. Dashboard shows [W] and
//   labels read "This Week's Bias / Next Week's Bias."
//
// OVERNIGHT / NEXT SESSION MODE:
// When enabled, a carrot arrow is placed on the LAST candle of each session via
// plotshape offset=-1. No repainting — the shape fires only when isResUpdate
// confirms a closed bar, and offset shifts it back one bar onto the final candle
// of the prior session.
// The "Tomorrow's Bias" dashboard row shows "—" from 4AM–3:59PM ET. It populates
// at 4:00 PM ET (confirmed daily close) and resets back to "—" at 4:00 AM ET.
// Requires TradingView Extended Hours to be ON for the 4PM trigger on intraday
// charts; without Extended Hours the arrow still lands correctly on the prior
// session's close bar, but the dashboard row will always show "—" intraday.
//
// BARS-BACK LIMITATION:
// Pine Script caps history at max_bars_back bars (set to 5000 here, roughly 20
// years on a daily chart). Free TradingView accounts may only have ~5 years of
// daily history (~1250 bars). More history = better matrix calibration. Watch the
// "Sample Size" readout — if it falls below your configured minimum (default: 30
// transitions), treat all probabilities with extra skepticism.
//
// NO-LOOKAHEAD GUARANTEE:
// Every calculation uses only historically confirmed data. States are computed
// from completed bars via request.security with lookahead=barmerge.lookahead_off.
// The bias shown is based exclusively on the last confirmed close and will not
// change until the next bar confirms.
//
// DISCLAIMER:
// Historical-tendency tool only. Not financial advice. Past regime probabilities
// do not guarantee future outcomes. Always apply your own risk management.
//
// ============================================================================

// ============================================================================
// SECTION 1 — INPUTS
// ============================================================================

var string grpRes    = "Regime Resolution"
var string grpState  = "State Classification"
var string grpMatrix = "Transition Matrix"
var string grpBias   = "Bias Output"
var string grpVis    = "Visuals"

// Resolution
i_resolution = input.string("Daily", "Regime Resolution",
     options=["Daily", "Weekly", "Monthly"], group=grpRes,
     tooltip="Daily: regime from closed daily bars (any chart). Weekly: regime from closed weekly bars, best viewed on the daily chart — shows [W]. Monthly: regime from closed monthly bars, best viewed on the weekly or daily chart — shows [M]. All labels update accordingly.")

// State classification
i_lookback   = input.int  (5,    "State Lookback (bars)",
     minval=2, maxval=50, group=grpState,
     tooltip="Number of completed bars at the selected resolution to measure the trailing return over.")
i_bullThresh = input.float(0.5,  "Bull Threshold (%)",
     minval=0.01, maxval=20.0, step=0.1, group=grpState,
     tooltip="If the trailing return (raw or ATR-normalised) exceeds this value, the state is BULL.")
i_bearThresh = input.float(0.5,  "Bear Threshold (%)",
     minval=0.01, maxval=20.0, step=0.1, group=grpState,
     tooltip="If the trailing return falls below the negative of this value, the state is BEAR.")
i_useAtrNorm = input.bool (true, "ATR-Normalise Thresholds", group=grpState,
     tooltip="Divides raw % return by ATR/price, making thresholds instrument- and volatility-agnostic.")
i_atrLen     = input.int  (14,   "ATR Period (for normalisation)",
     minval=2, maxval=100, group=grpState)

// Transition matrix
i_matrixBars = input.int  (1000, "Matrix Lookback (bars; 0 = all available)",
     minval=0, maxval=5000, group=grpMatrix,
     tooltip="Number of historical bars (at the selected resolution) included in the transition count. 0 uses all available history up to the max_bars_back cap of 5000.")

// Bias output
i_biasThresh = input.float(55.0, "Bias Confidence Threshold (%)",
     minval=50.0, maxval=99.0, step=0.5, group=grpBias,
     tooltip="If P(Bull) OR P(Bear) exceeds this %, the bias fires. Otherwise the output is NEUTRAL.")
i_minSample  = input.int  (30,   "Min Transitions for Confidence Warning",
     minval=5, maxval=500, group=grpBias,
     tooltip="Displays a warning if total transitions in the matrix fall below this number.")
i_overnightMode = input.bool(false, "Overnight / Next Session Mode", group=grpBias,
     tooltip="Adds a carrot arrow on the LAST candle of each session (offset=-1, no repainting). Dashboard shows a 'Tomorrow's Bias' row: hidden until 4PM ET, populated 4PM–4AM ET, resets at 4AM. Requires Extended Hours ON in TradingView for the 4PM trigger on intraday charts.")

// Visuals
i_showTable   = input.bool  (true,        "Show Dashboard Table",          group=grpVis)
i_showMatrix  = input.bool  (true,        "Show Transition Matrix Grid",   group=grpVis)
i_showBgTint  = input.bool  (true,        "Show Background Tint",          group=grpVis)
i_showHistory = input.bool  (true,        "Show Historical State Markers", group=grpVis)
i_tblPos      = input.string("Top Right", "Table Position",
     options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=grpVis)
i_colorBull   = input.color (color.new(#00c087, 0),  "Bull Colour",     group=grpVis)
i_colorBear   = input.color (color.new(#ff3b30, 0),  "Bear Colour",     group=grpVis)
i_colorSide   = input.color (color.new(#8e8e93, 0),  "Sideways Colour", group=grpVis)
i_bgAlpha     = input.int   (93, "Background Tint Opacity (0=solid, 100=invisible)",
     minval=70, maxval=100, group=grpVis)
i_showDayBias  = input.bool  (true,        "Show Session-Start Bias Markers",  group=grpVis,
     tooltip="Plots one marker at the FIRST bar of each new session: green triangle up = Bullish, red triangle down = Bearish, yellow diamond = Neutral/Chop. On intraday charts this appears at the session open. On the daily chart it sits on that day's candle — useful for auditing historical signals.")
i_colorNeutral = input.color (color.new(color.yellow, 0), "Neutral Marker Colour", group=grpVis)
i_markerSize   = input.string("Normal",    "Marker Size",
     options=["Tiny","Small","Normal","Large"], group=grpVis)

// ============================================================================
// SECTION 2 — CONFIRMED RESOLUTION DATA (NO LOOKAHEAD)
// ============================================================================
// All request.security calls use lookahead=barmerge.lookahead_off.
// This guarantees we only ever see the most recently COMPLETED (closed) bar at
// the selected resolution — never the in-progress live bar. On a chart whose
// timeframe matches the resolution, this is identical to reading close/atr directly.
//
// The state classification function runs inside security() at the chosen
// resolution, so every historical bar gets its own state computed with only data
// available up to and including that bar (no future information).

string _res = i_resolution == "Weekly" ? "W" : i_resolution == "Monthly" ? "M" : "D"

f_stateAtRes() =>
    float priceNow  = close
    float priceBack = close[i_lookback]
    float retPct    = not na(priceBack) and priceBack != 0.0
                      ? (priceNow - priceBack) / priceBack * 100.0
                      : 0.0
    float atrVal    = ta.atr(i_atrLen)
    float normFactor = i_useAtrNorm and not na(atrVal) and atrVal > 0.0 and priceNow > 0.0
                       ? atrVal / priceNow * 100.0
                       : 1.0
    float adjReturn  = i_useAtrNorm ? retPct / math.max(normFactor, 0.0001) : retPct
    // States: 0 = BULL, 1 = BEAR, 2 = SIDEWAYS
    adjReturn > i_bullThresh ? 0 : adjReturn < -i_bearThresh ? 1 : 2

int resState  = request.security(syminfo.tickerid, _res, f_stateAtRes(), lookahead=barmerge.lookahead_off)
int resBarIdx = request.security(syminfo.tickerid, _res, bar_index,      lookahead=barmerge.lookahead_off)

// Detect when a new confirmed bar at the chosen resolution has become available.
// On intraday charts: fires on the first bar of each new session (when resBarIdx
// increments). The bias is then stable for the rest of that session.
var int lastResBarIdx = na
bool isResUpdate = not na(resBarIdx) and (na(lastResBarIdx) or resBarIdx != lastResBarIdx)
if isResUpdate
    lastResBarIdx := resBarIdx

// ============================================================================
// SECTION 3 — TRANSITION MATRIX (ROLLING, INCREMENTAL, NO LOOKAHEAD)
// ============================================================================
// We maintain a rolling queue of the last (i_matrixBars + 1) confirmed states.
// From N+1 consecutive states we extract N transitions.
//
// On each new confirmed bar:
//   1. Push the new state onto the back of the queue.
//   2. Add the new transition (state[t-1] → state[t]) to the count array.
//   3. If the queue exceeds the window capacity, pop the oldest state and
//      subtract the corresponding transition — implementing the rolling window.
//
// Count matrix layout (flat 9-element array, row-major):
//   index = fromState * 3 + toState   (BULL=0, BEAR=1, SIDEWAYS=2)

var float[] transCount  = array.new_float(9, 0.0)
var int[]   stateBuffer = array.new_int(0)

if isResUpdate
    array.push(stateBuffer, resState)
    int bufLen = array.size(stateBuffer)

    if bufLen >= 2
        int fromSt = array.get(stateBuffer, bufLen - 2)
        int toSt   = array.get(stateBuffer, bufLen - 1)
        int idx    = fromSt * 3 + toSt
        array.set(transCount, idx, array.get(transCount, idx) + 1.0)

    int bufCap = i_matrixBars > 0 ? i_matrixBars + 1 : 5001
    if i_matrixBars > 0 and bufLen > bufCap
        int removedFrom = array.shift(stateBuffer)
        int newOldest   = array.get(stateBuffer, 0)
        int removeIdx   = removedFrom * 3 + newOldest
        array.set(transCount, removeIdx,
                  math.max(0.0, array.get(transCount, removeIdx) - 1.0))

// Row-normalised probability for a single "from" state.
// Returns [P(→BULL), P(→BEAR), P(→SIDE)] in %.
// Defaults to 33.3% each if the state has never been observed.
f_probRow(int fromSt, float[] counts) =>
    float pB  = array.get(counts, fromSt * 3 + 0)
    float pBr = array.get(counts, fromSt * 3 + 1)
    float pS  = array.get(counts, fromSt * 3 + 2)
    float rowSum = pB + pBr + pS
    float scale  = rowSum > 0.0 ? 100.0 / rowSum : 0.0
    float rBull = rowSum > 0.0 ? pB  * scale : 33.33
    float rBear = rowSum > 0.0 ? pBr * scale : 33.33
    float rSide = rowSum > 0.0 ? pS  * scale : 33.33
    [rBull, rBear, rSide]

// ============================================================================
// SECTION 4 — BIAS OUTPUT
// ============================================================================
// Look up the current confirmed state's row in the probability matrix.
// This value is stable across the session — it is set the moment the prior bar
// confirms and will not change until the next confirmed close.

int curState = resState

[pBull0, pBear0, pSide0] = f_probRow(0, transCount)   // BULL  row
[pBull1, pBear1, pSide1] = f_probRow(1, transCount)   // BEAR  row
[pBull2, pBear2, pSide2] = f_probRow(2, transCount)   // SIDEWAYS row

float pBullNext = curState == 0 ? pBull0 : curState == 1 ? pBull1 : pBull2
float pBearNext = curState == 0 ? pBear0 : curState == 1 ? pBear1 : pBear2
float pSideNext = curState == 0 ? pSide0 : curState == 1 ? pSide1 : pSide2

float totalTrans = 0.0
for i = 0 to 8
    totalTrans += array.get(transCount, i)
bool lowSample = totalTrans < float(i_minSample)

int biasDir = pBullNext >= i_biasThresh ? 1 : pBearNext >= i_biasThresh ? -1 : 0

string stateLabel = curState == 0 ? "BULL" : curState == 1 ? "BEAR" : "SIDEWAYS"
color  stateColor = curState == 0 ? i_colorBull : curState == 1 ? i_colorBear : i_colorSide
string biasLabel  = biasDir ==  1 ? "▲  BULLISH" : biasDir == -1 ? "▼  BEARISH" : "◆  NEUTRAL"
color  biasColor  = biasDir ==  1 ? i_colorBull  : biasDir == -1 ? i_colorBear  : i_colorSide

// ============================================================================
// SECTION 5 — OVERNIGHT WINDOW LOGIC
// ============================================================================
// ET time gate: 4:00 PM – 3:59 AM (America/New_York).
// overnightDisplayBias is captured at the confirmed close (isResUpdate fires)
// and held for display throughout the overnight window.
// It resets to na at 4:00 AM ET — detected as the first bar that crosses from
// inside the window (< 4:00 AM) to outside (>= 4:00 AM, < 4:00 PM).
//
// On the DAILY chart every bar is at 4:00 PM ET so isOvernightWindow is always
// true — "Tomorrow's Bias" displays continuously, which is correct behaviour
// since each bar is itself a confirmed close.

int  _etMins         = hour(time, "America/New_York") * 60 + minute(time, "America/New_York")
bool isOvernightWindow = i_overnightMode and (_etMins >= 16 * 60 or _etMins < 4 * 60)

var int overnightDisplayBias = na

// Capture bias at each confirmed close
if isResUpdate
    overnightDisplayBias := biasDir

// Reset at 4:00 AM ET: detect transition from inside to outside the window
bool _nowAfterReset = _etMins >= 4 * 60 and _etMins < 16 * 60
bool _prevInWindow  = _etMins[1] >= 16 * 60 or _etMins[1] < 4 * 60
if i_overnightMode and _nowAfterReset and _prevInWindow
    overnightDisplayBias := na

string overnightBiasLabel = na(overnightDisplayBias) ? "—" :
                            overnightDisplayBias ==  1 ? "▲  BULLISH" :
                            overnightDisplayBias == -1 ? "▼  BEARISH" : "◆  NEUTRAL"
color  overnightBiasColor = na(overnightDisplayBias) ? color.gray :
                            overnightDisplayBias ==  1 ? i_colorBull  :
                            overnightDisplayBias == -1 ? i_colorBear  : i_colorSide

// ============================================================================
// SECTION 6 — BACKGROUND TINT
// ============================================================================

if i_showBgTint
    bgcolor(biasDir ==  1 ? color.new(i_colorBull, i_bgAlpha) :
            biasDir == -1 ? color.new(i_colorBear, i_bgAlpha) :
                            color.new(i_colorSide, i_bgAlpha),
            title="Bias Background Tint")

// ============================================================================
// SECTION 7 — VISUAL MARKERS
// ============================================================================

// ── Historical state markers (tiny, every bar) ───────────────────────────────
plotshape(i_showHistory and curState == 0, title="State: BULL",
          style=shape.triangleup, location=location.belowbar,
          color=i_colorBull, size=size.tiny)
plotshape(i_showHistory and curState == 1, title="State: BEAR",
          style=shape.triangledown, location=location.abovebar,
          color=i_colorBear, size=size.tiny)

_mSz = i_markerSize == "Tiny"  ? size.tiny  :
       i_markerSize == "Small" ? size.small :
       i_markerSize == "Large" ? size.large : size.normal

// ── Session-start bias markers (first bar of each new session) ───────────────
// Green ▲ below bar = BULLISH for the session ahead
// Red   ▼ above bar = BEARISH for the session ahead
// Yellow ◆ below bar = NEUTRAL / Chop
plotshape(i_showDayBias and isResUpdate and biasDir ==  1, title="Session Bias: BULLISH",
          style=shape.triangleup,   location=location.belowbar,
          color=i_colorBull,    size=_mSz)
plotshape(i_showDayBias and isResUpdate and biasDir == -1, title="Session Bias: BEARISH",
          style=shape.triangledown, location=location.abovebar,
          color=i_colorBear,    size=_mSz)
plotshape(i_showDayBias and isResUpdate and biasDir ==  0, title="Session Bias: NEUTRAL",
          style=shape.diamond,      location=location.belowbar,
          color=i_colorNeutral, size=_mSz)

// ── Overnight close arrows (offset=-1, last candle of prior session) ─────────
// isResUpdate fires at the FIRST bar after the confirmed close (4:05 PM with
// Extended Hours ON, or 9:30 AM next day without Extended Hours). offset=-1
// shifts the plotshape back one bar — landing on the final candle of the prior
// session. No repainting: we only fire on confirmed, closed bars.
plotshape(i_overnightMode and isResUpdate and biasDir ==  1, title="Overnight Close: BULLISH",
          style=shape.arrowup,   location=location.belowbar,
          color=i_colorBull, size=_mSz, offset=-1)
plotshape(i_overnightMode and isResUpdate and biasDir == -1, title="Overnight Close: BEARISH",
          style=shape.arrowdown, location=location.abovebar,
          color=i_colorBear, size=_mSz, offset=-1)
plotshape(i_overnightMode and isResUpdate and biasDir ==  0, title="Overnight Close: NEUTRAL",
          style=shape.circle,    location=location.belowbar,
          color=i_colorNeutral, size=_mSz, offset=-1)

// ============================================================================
// SECTION 8 — DASHBOARD TABLE
// ============================================================================
// 14 rows: header, current state, today's bias, 3 probabilities,
// tomorrow's bias (overnight mode row — empty when mode is off),
// sample size, threshold, 5 matrix rows.

string _resTag       = i_resolution == "Weekly"  ? "W" : i_resolution == "Monthly" ? "M" : "D"
string _hdrLabel     = "MARKOV REGIME BIAS  [" + _resTag + "]"
string _sessionLbl   = i_resolution == "Weekly"  ? "This Week's Bias"   :
                       i_resolution == "Monthly" ? "This Month's Bias"  : "Today's Session Bias"
string _nextLbl      = i_resolution == "Weekly"  ? "Next Week's Bias"   :
                       i_resolution == "Monthly" ? "Next Month's Bias"  : "Tomorrow's Bias"
string _pBullLbl     = i_resolution == "Weekly"  ? "P(Bull) next week"  :
                       i_resolution == "Monthly" ? "P(Bull) next month" : "P(Bull) tomorrow"
string _pBearLbl     = i_resolution == "Weekly"  ? "P(Bear) next week"  :
                       i_resolution == "Monthly" ? "P(Bear) next month" : "P(Bear) tomorrow"
string _pSideLbl     = i_resolution == "Weekly"  ? "P(Side) next week"  :
                       i_resolution == "Monthly" ? "P(Side) next month" : "P(Side) tomorrow"
string _lookbackUnit = i_resolution == "Weekly"  ? "w" : i_resolution == "Monthly" ? "m" : "d"

string tblPosStr = i_tblPos
var table dash   = table.new(
     tblPosStr == "Top Left"     ? position.top_left     :
     tblPosStr == "Bottom Right" ? position.bottom_right :
     tblPosStr == "Bottom Left"  ? position.bottom_left  : position.top_right,
     4, 14,
     border_width = 1,
     border_color = color.new(color.gray, 70),
     frame_width  = 2,
     frame_color  = color.new(color.gray, 50))

if barstate.islast and i_showTable
    color hdrBg   = color.new(#0d1b2a, 15)
    color rowBg   = color.new(#0d1b2a, 60)
    color txtDim  = color.new(color.white, 50)
    color txtFull = color.white

    // ── Row 0: Title ──────────────────────────────────────────────────────
    table.cell(dash, 0, 0, _hdrLabel,
               bgcolor=hdrBg, text_color=txtFull,
               text_size=size.small, text_fontstyle=font.style_bold,
               text_halign=text.align_center)
    table.merge_cells(dash, 0, 0, 3, 0)

    // ── Row 1: Current State ──────────────────────────────────────────────
    table.cell(dash, 0, 1, "Current State",
               bgcolor=rowBg, text_color=txtDim,
               text_size=size.small, text_halign=text.align_left)
    table.merge_cells(dash, 0, 1, 1, 1)
    table.cell(dash, 2, 1, stateLabel,
               bgcolor=color.new(stateColor, 55),
               text_color=txtFull, text_size=size.normal,
               text_fontstyle=font.style_bold, text_halign=text.align_center)
    table.merge_cells(dash, 2, 1, 3, 1)

    // ── Row 2: Today's Session Bias ───────────────────────────────────────
    table.cell(dash, 0, 2, _sessionLbl,
               bgcolor=rowBg, text_color=txtDim,
               text_size=size.small, text_halign=text.align_left)
    table.merge_cells(dash, 0, 2, 1, 2)
    table.cell(dash, 2, 2, biasLabel,
               bgcolor=color.new(biasColor, 30),
               text_color=biasColor, text_size=size.normal,
               text_fontstyle=font.style_bold, text_halign=text.align_center)
    table.merge_cells(dash, 2, 2, 3, 2)

    // ── Row 3: P(Bull) ────────────────────────────────────────────────────
    table.cell(dash, 0, 3, _pBullLbl,
               bgcolor=rowBg, text_color=txtDim, text_size=size.small, text_halign=text.align_left)
    table.merge_cells(dash, 0, 3, 1, 3)
    table.cell(dash, 2, 3, str.tostring(pBullNext, "#.1") + "%",
               bgcolor=color.new(color.green, 50), text_color=txtFull,
               text_size=size.normal, text_fontstyle=font.style_bold, text_halign=text.align_center)
    table.merge_cells(dash, 2, 3, 3, 3)

    // ── Row 4: P(Bear) ────────────────────────────────────────────────────
    table.cell(dash, 0, 4, _pBearLbl,
               bgcolor=rowBg, text_color=txtDim, text_size=size.small, text_halign=text.align_left)
    table.merge_cells(dash, 0, 4, 1, 4)
    table.cell(dash, 2, 4, str.tostring(pBearNext, "#.1") + "%",
               bgcolor=color.new(color.red, 50), text_color=txtFull,
               text_size=size.normal, text_fontstyle=font.style_bold, text_halign=text.align_center)
    table.merge_cells(dash, 2, 4, 3, 4)

    // ── Row 5: P(Sideways) ────────────────────────────────────────────────
    table.cell(dash, 0, 5, _pSideLbl,
               bgcolor=rowBg, text_color=txtDim, text_size=size.small, text_halign=text.align_left)
    table.merge_cells(dash, 0, 5, 1, 5)
    table.cell(dash, 2, 5, str.tostring(pSideNext, "#.1") + "%",
               bgcolor=color.new(color.gray, 50), text_color=txtFull,
               text_size=size.normal, text_fontstyle=font.style_bold, text_halign=text.align_center)
    table.merge_cells(dash, 2, 5, 3, 5)

    // ── Row 6: Tomorrow's Bias (overnight mode only) ──────────────────────
    // Shows "—" outside 4PM–4AM ET window, populates within it.
    // When overnight mode is off this row is left empty (no visible cells drawn).
    if i_overnightMode
        table.cell(dash, 0, 6, _nextLbl,
                   bgcolor=rowBg, text_color=txtDim,
                   text_size=size.small, text_halign=text.align_left)
        table.merge_cells(dash, 0, 6, 1, 6)
        bool   _ovnActive = isOvernightWindow and not na(overnightDisplayBias)
        string _ovnStr    = _ovnActive ? overnightBiasLabel : "—"
        color  _ovnBg     = _ovnActive ? color.new(overnightBiasColor, 30) : color.new(color.gray, 75)
        color  _ovnTxt    = _ovnActive ? overnightBiasColor : color.new(color.white, 65)
        table.cell(dash, 2, 6, _ovnStr,
                   bgcolor=_ovnBg, text_color=_ovnTxt,
                   text_size=size.normal, text_fontstyle=font.style_bold, text_halign=text.align_center)
        table.merge_cells(dash, 2, 6, 3, 6)

    // ── Row 7: Sample Size ────────────────────────────────────────────────
    color  sampleBg  = lowSample ? color.new(color.orange, 35) : color.new(#005f73, 40)
    string sampleStr = str.tostring(int(totalTrans)) + (lowSample ? "  ⚠ LOW" : " transitions")
    table.cell(dash, 0, 7, "Sample Size",
               bgcolor=rowBg, text_color=txtDim, text_size=size.small, text_halign=text.align_left)
    table.merge_cells(dash, 0, 7, 1, 7)
    table.cell(dash, 2, 7, sampleStr,
               bgcolor=sampleBg, text_color=txtFull,
               text_size=size.small, text_halign=text.align_center)
    table.merge_cells(dash, 2, 7, 3, 7)

    // ── Row 8: Threshold info ─────────────────────────────────────────────
    table.cell(dash, 0, 8,
               "Bias threshold: " + str.tostring(i_biasThresh, "#.0") + "%  |  " +
               "Lookback: " + str.tostring(i_lookback) + _lookbackUnit,
               bgcolor=color.new(#0d1b2a, 40), text_color=color.new(color.white, 65),
               text_size=size.tiny, text_halign=text.align_center)
    table.merge_cells(dash, 0, 8, 3, 8)

    // ── Rows 9-13: Transition Matrix Grid (optional) ──────────────────────
    if i_showMatrix
        // Row 9: Section divider
        table.cell(dash, 0, 9, "─── Transition Matrix ───",
                   bgcolor=color.new(#0d1b2a, 40),
                   text_color=color.new(color.white, 60),
                   text_size=size.tiny, text_halign=text.align_center)
        table.merge_cells(dash, 0, 9, 3, 9)

        // Row 10: Column headers
        table.cell(dash, 0, 10, "FROM \\ TO",
                   bgcolor=color.new(color.gray, 65), text_color=txtDim, text_size=size.tiny)
        table.cell(dash, 1, 10, "→ BULL",
                   bgcolor=color.new(color.green, 65), text_color=txtFull, text_size=size.tiny, text_halign=text.align_center)
        table.cell(dash, 2, 10, "→ BEAR",
                   bgcolor=color.new(color.red,   65), text_color=txtFull, text_size=size.tiny, text_halign=text.align_center)
        table.cell(dash, 3, 10, "→ SIDE",
                   bgcolor=color.new(color.gray,  65), text_color=txtFull, text_size=size.tiny, text_halign=text.align_center)

        // Rows 11-13: One row per "from" state
        float[] allProbs  = array.from(pBull0, pBear0, pSide0,
                                       pBull1, pBear1, pSide1,
                                       pBull2, pBear2, pSide2)
        string[] rowLabels = array.from("BULL →", "BEAR →", "SIDE →")

        for int fromSt = 0 to 2
            int rowIdx = 11 + fromSt
            color rowLabelBg = fromSt == 0 ? color.new(color.green, 60) :
                               fromSt == 1 ? color.new(color.red,   60) :
                                             color.new(color.gray,  60)
            table.cell(dash, 0, rowIdx, array.get(rowLabels, fromSt),
                       bgcolor=rowLabelBg, text_color=txtFull, text_size=size.tiny)

            for int toSt = 0 to 2
                float p     = array.get(allProbs, fromSt * 3 + toSt)
                int   alpha = int(math.max(15, math.min(80, 80 - p * 0.6)))
                color cellBg = toSt == 0 ? color.new(color.green, alpha) :
                               toSt == 1 ? color.new(color.red,   alpha) :
                                           color.new(color.gray,  alpha)
                float rowMax = math.max(array.get(allProbs, fromSt * 3 + 0),
                               math.max(array.get(allProbs, fromSt * 3 + 1),
                                        array.get(allProbs, fromSt * 3 + 2)))
                bool isMax = p >= rowMax - 0.01
                table.cell(dash, toSt + 1, rowIdx,
                           str.tostring(p, "#.0") + "%",
                           bgcolor=cellBg, text_color=txtFull,
                           text_size=size.tiny, text_halign=text.align_center,
                           text_fontstyle=isMax ? font.style_bold : font.style_normal)

// ============================================================================
// SECTION 9 — ALERTS
// ============================================================================
// prevBiasDir holds the prior session's bias so flip conditions detect
// genuine state changes (not intraday noise — isResUpdate only fires once
// per confirmed close).

var int prevBiasDir = na

bool flipBullish = not na(prevBiasDir) and prevBiasDir != 1  and biasDir == 1
bool flipBearish = not na(prevBiasDir) and prevBiasDir != -1 and biasDir == -1
bool flipNeutral = not na(prevBiasDir) and prevBiasDir != 0  and biasDir == 0

if isResUpdate
    prevBiasDir := biasDir

alertcondition(flipBullish, title="MRB — Bias flipped BULLISH",
    message="[Markov Regime Bias] {{ticker}} bias flipped to BULLISH on {{time}}. Check the dashboard for P(Bull/Bear/Sideways).")

alertcondition(flipBearish, title="MRB — Bias flipped BEARISH",
    message="[Markov Regime Bias] {{ticker}} bias flipped to BEARISH on {{time}}. Check the dashboard for P(Bull/Bear/Sideways).")

alertcondition(flipNeutral, title="MRB — Bias flipped NEUTRAL",
    message="[Markov Regime Bias] {{ticker}} bias flipped to NEUTRAL on {{time}} — no strong directional edge detected.")

alertcondition(lowSample, title="MRB — Low Sample Size Warning",
    message="[Markov Regime Bias] {{ticker}} transition matrix has fewer than the configured minimum transitions. Interpret probabilities with caution.")

// Overnight window alerts: fire once at the moment the window opens (4PM ET
// transition). Use these to get notified when the overnight entry window is live.
bool windowOpened = i_overnightMode and isOvernightWindow and not isOvernightWindow[1]

alertcondition(windowOpened and biasDir ==  1, title="MRB — Overnight Window Opened: BULLISH",
    message="[Markov Regime Bias] {{ticker}} overnight window opened at {{time}}. Bias: BULLISH. 15-minute index entry window is now live.")
alertcondition(windowOpened and biasDir == -1, title="MRB — Overnight Window Opened: BEARISH",
    message="[Markov Regime Bias] {{ticker}} overnight window opened at {{time}}. Bias: BEARISH. 15-minute index entry window is now live.")
alertcondition(windowOpened and biasDir ==  0, title="MRB — Overnight Window Opened: NEUTRAL",
    message="[Markov Regime Bias] {{ticker}} overnight window opened at {{time}}. Bias: NEUTRAL — no strong directional edge, consider sitting out.")
